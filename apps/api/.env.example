# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Frontend URL — used for links in emails, redirects, etc.
FRONTEND_URL=http://localhost:5173

# PostgreSQL
# NOTE: If using infra/docker-compose.yml for dev, postgres is mapped to port 5433
DATABASE_URL=postgresql://agentlens:agentlens@localhost:5433/agentlens
DATABASE_SSL=false
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2

# Redis (BullMQ)
# NOTE: If using infra/docker-compose.yml for dev, redis is mapped to port 6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# Auth secrets — generate with: openssl rand -hex 32
HMAC_SECRET=
JWT_SECRET=

# Resend (email) — optional, needed for email alerts
RESEND_API_KEY=re_your_key_here
ALERT_EMAIL_FROM=alerts@yourdomain.com
