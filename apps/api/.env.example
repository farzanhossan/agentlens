# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://agentlens:agentlens@localhost:5432/agentlens
DATABASE_SSL=false
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Resend (email)
RESEND_API_KEY=re_your_key_here
WAITLIST_EMAIL_FROM=hello@agentlens.ai
