# These are Cloudflare Worker secrets — set with `wrangler secret put <NAME>`
# Copy this file to .dev.vars for local `wrangler dev` usage.

# Shared HMAC-SHA256 secret used to sign and verify API keys at the edge.
# Generate with: openssl rand -hex 32
HMAC_SECRET=change-me-to-a-random-32-byte-hex-secret

# Upstash Redis REST credentials (used for rate-limiting + BullMQ queue push).
# Create a free database at https://upstash.com and copy the REST URL/token.
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Runtime environment — controls logging verbosity
ENVIRONMENT=development
