{
  "name": "@farzanhossans/agentlens-ingest-worker",
  "version": "0.1.0",
  "private": true,
  "description": "AgentLens edge ingestion worker — Cloudflare Worker + Hono.js",
  "scripts": {
    "dev": "wrangler dev --env development",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.31.3",
    "hono": "^4.3.7",
    "zod": "^3.23.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240524.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.57.2"
  }
}
