{
  "name": "@agentlens/core",
  "version": "0.1.0",
  "description": "Core tracer SDK for AgentLens — AI agent observability",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build && pnpm test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "observability",
    "llm",
    "tracing",
    "openai",
    "anthropic",
    "langchain",
    "monitoring"
  ],
  "author": "Farzan Hossan <farzanhossans@gmail.com>",
  "license": "MIT",
  "homepage": "https://agentlens.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/farzanhossan/agentlens",
    "directory": "packages/sdk-core"
  },
  "bugs": {
    "url": "https://github.com/farzanhossan/agentlens/issues"
  },
  "dependencies": {
    "pako": "^2.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/pako": "^2.0.3",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsup": "^8.5.1",
    "vitest": "^1.6.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
