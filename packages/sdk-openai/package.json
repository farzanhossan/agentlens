{
  "name": "@agentlens/openai",
  "version": "0.1.0",
  "description": "AgentLens auto-instrumentation for the OpenAI Node.js SDK",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "dependencies": {
    "@agentlens/core": "workspace:*",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "openai": "^4.47.1",
    "vitest": "^1.6.0"
  }
}
