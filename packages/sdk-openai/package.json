{
  "name": "@farzanhossans/agentlens-openai",
  "version": "0.1.3",
  "description": "OpenAI auto-instrumentation for AgentLens",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "observability",
    "llm",
    "tracing",
    "openai",
    "gpt-4",
    "chatgpt",
    "monitoring"
  ],
  "author": "Farzan Hossan <farzanhossans@gmail.com>",
  "license": "MIT",
  "homepage": "https://agentlens.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/farzanhossan/agentlens",
    "directory": "packages/sdk-openai"
  },
  "bugs": {
    "url": "https://github.com/farzanhossan/agentlens/issues"
  },
  "peerDependencies": {
    "@farzanhossans/agentlens-core": ">=0.1.0",
    "openai": ">=4.0.0"
  },
  "dependencies": {
    "@farzanhossans/agentlens-core": "workspace:*",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "openai": "^4.47.1",
    "tsup": "^8.5.1",
    "vitest": "^1.6.0"
  }
}
