# ============================================================================
# AgentLens — Self-Hosted Production Environment
# ============================================================================
# Copy this file to .env in the same directory:
#   cp .env.prod.example .env
#
# Then fill in the secrets below before running:
#   docker compose -f docker-compose.prod.yml up -d --build
# ============================================================================

# ── Secrets (REQUIRED — generate with: openssl rand -hex 32) ──────────────
JWT_SECRET=
HMAC_SECRET=

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=agentlens
POSTGRES_USER=agentlens
POSTGRES_PASSWORD=agentlens

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=agentlens

# ── Ports (change if you have conflicts) ──────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000
PROXY_PORT=8080

# ── Frontend URLs (update if using a reverse proxy / custom domain) ───────
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ── Email alerts (optional) ──────────────────────────────────────────────
# RESEND_API_KEY=re_your_key_here
# ALERT_EMAIL_FROM=alerts@yourdomain.com
